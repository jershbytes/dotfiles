# GitHub
Host github.com
  HostName github.com
  User git
  Port 22
  IdentityFile ~/.ssh/git/key
  IdentitiesOnly yes

# Codeberg
Host codeberg.org
  HostName codeberg.org
  User git
  Port 22
  IdentityFile ~/.ssh/git/key
  IdentitiesOnly yes

# Gitlab
Host git.jershlabs.xyz
  HostName git.jershlabs.xyz
  User git
  Port 22
  IdentityFile ~/.ssh/git/key
  IdentitiesOnly yes

# Proxmox VE hosts
Host pve*
  User root
  Port 22
  IdentityFile ~/.ssh/proxmox/key

# All other hosts in the lab
Host *
  Port 22
  User adm_rossj
  IdentityFile ~/.ssh/lab/key