#!/usr/bin/env bash

PIDFILE="/tmp/wofi.pid"

if [ -f "$PIDFILE" ]; then
    pid="$(cat "$PIDFILE")"
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid"
        rm -f "$PIDFILE"
        exit 0
    fi
    rm -f "$PIDFILE"
fi

/usr/bin/wofi --show drun --conf "$HOME/.config/wofi/config" --style "$HOME/.config/wofi/style.css" &
echo $! > "$PIDFILE"
disown