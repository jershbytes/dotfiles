config-file = ~/.config/ghostty/themes/dracula-alucard.conf

window-theme = ghostty
window-height = 35
window-width = 100
background-opacity = 0.95
font-size = 12
gtk-titlebar = false
confirm-close-surface = false
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard


#keybind = ctrl+up=scroll_page_lines:5
#keybind = ctrl+down=scroll_page_lines:-5

keybind = ctrl+up=scroll_page_up
keybind = ctrl+down=scroll_page_down