#!/usr/bin/env bash

set -euo pipefail

{{ if eq .osid "rhel" }}

# Install packages using dnf
sudo dnf install -y{{- range .packages.epel }} {{ . | quote }}
{{- end }}

# Install packages using homebrew
brew bundle --file=/dev/stdin <<EOF
{{ range .packages.brews -}}
brew {{ . | quote }}
{{ end -}}
EOF

sudo chmod +x /usr/local/bin/update
{{ end }}