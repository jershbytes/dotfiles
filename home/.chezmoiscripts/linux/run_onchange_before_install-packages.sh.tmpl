#!/usr/bin/env bash

set -euo pipefail

{{ if eq .osid "ubuntu" }}

# Install packages using dnf
sudo apt install -y{{- range .packages.ubuntu }} {{ . | quote }}
{{- end }}

# Install packages using homebrew
brew bundle --file=/dev/stdin <<EOF
{{ range .packages.brews -}}
brew {{ . | quote }}
{{ end -}}
EOF
{{ end }}